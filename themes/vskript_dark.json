{
	"$schema": "vscode://schemas/color-theme",
	"name": "VSkript",
	"type": "dark",
	"include": "./dark_plus.json",
	"colors": {},
	"tokenColors": [
		{ "settings": { "foreground": "#ff0000" }, "scope": "color.red" },
		{ "settings": { "foreground": "#ff8000" }, "scope": "color.orange" },
		{ "settings": { "foreground": "#ffff00" }, "scope": "color.yellow" },
		{ "settings": { "foreground": "#00ff00" }, "scope": "color.lightgreen" },
		{ "settings": { "foreground": "#008000" }, "scope": "color.green" },
		{ "settings": { "foreground": "#00ffff" }, "scope": "color.lightblue" },
		{ "settings": { "foreground": "#0080ff" }, "scope": "color.blue" },
		{ "settings": { "foreground": "#8000ff" }, "scope": "color.puple" },
		{ "settings": { "foreground": "#ff80ff" }, "scope": "color.pink" },

		{ "settings": { "foreground": "#f16745" }, "scope": "color.pink2" },
		{ "settings": { "foreground": "#ffc65d" }, "scope": "color.pink3" },
		{ "settings": { "foreground": "#7bc8a4" }, "scope": "color.pink4" },
		{ "settings": { "foreground": "#4cc3d9" }, "scope": "color.pink5" },
		{ "settings": { "foreground": "#93648d" }, "scope": "color.pink6" },
		{ "settings": { "foreground": "#333333" }, "scope": "color.pink7" },
		{ "settings": { "foreground": "#b54d34" }, "scope": "color.pink8" },
		{ "settings": { "foreground": "#bf9546" }, "scope": "color.pink9" },
		{ "settings": { "foreground": "#5c967b" }, "scope": "color.pink10" },
		{ "settings": { "foreground": "#3992a3" }, "scope": "color.pink11" },
		{ "settings": { "foreground": "#6e4b6a" }, "scope": "color.pink12" },
		{ "settings": { "foreground": "#303030" }, "scope": "color.pink13" },




		{
			"name": "VSkript Comment",
			"scope": [ "vskript.comment" ],
			"settings": { "foreground": "#6A9955", "fontStyle": "" }
		},
		{
			"name": "VSkript Docs Annotation",
			"scope": [ "vskript.docs.annotation" ],
			"settings": { "foreground": "#3992a3", "fontStyle": "" }
		},
		{
			"name": "VSkript Docs Parameter",
			"scope": [ "vskript.docs.parm" ],
			"settings": { "foreground": "#c0c0c0", "fontStyle": "" }
		},



		{
			"name": "VSkript Options",
			"scope": "vskript.options",
			"settings": { "foreground": "#C586C0", "fontStyle": "bold" }
		},
		{
			"name": "VSkript Options Variable ",
			"scope": "vskript.options.variable",
			"settings": { "foreground": "#C586C0", "fontStyle": "" }
		},



		{
			"name": "VSkript Aliases",
			"scope": "vskript.aliases",
			"settings": { "foreground": "#9cdcfe", "fontStyle": "bold" }
		},
		{
			"name": "VSkript Aliases",
			"scope": [
				"vskript.aliases.variable",
				"vskript.expr.minecraftitem",
				"vskript.expr.aliases",
				"vskript.type",
			],
			"settings": { "foreground": "#9cdcfe", "fontStyle": "" }
		},



		{
			"name": "VSkript Event, Command",
			"scope": [
				"vskript.event",
				"vskript.command"
			],
			"settings": { "foreground": "#DCDCAA", "fontStyle": "bold" }
		},
		{
			"name": "VSkript Command Label & Options",
			"scope": [
				"vskript.command.label",
				"vskript.command.options"
			],
			"settings": { "foreground": "#DCDCAA", "fontStyle": "" }
		},



		{
			"name": "VSkript Function",
			"scope": "vskript.function",
			"settings": { "foreground": "#569cd6", "fontStyle": "bold" }
		},
		{
			"name": "VSkript Expression Function",
			"scope": "vskript.expr.function",
			"settings": { "foreground": "#569cd6", "fontStyle": "" }
		},



		{
			"name": "VSkript Grammar",
			"scope":  "vskript.grammar",
			"settings": { "foreground": "#ff8000", "fontStyle": "bold" }
		},
		{
			"name": "VSkript Expression Grammar",
			"scope": "vskript.expr.grammar",
			"settings": { "fontStyle": "italic" }
		},
		{
			"name": "VSkript Expression Number",
			"scope": "vskript.expr.number",
			"settings": { "foreground": "#FFFFFF", "fontStyle": "" }
		},


		
		{
			"name": "VSkript Expression Text",
			"scope": "vskript.expr.text",
			"settings": { "foreground": "#ce9178", "fontStyle": "" }
		},

		
		{
			"name": "VSkript Variable Local",
			"scope": "vskript.variable.local",
			"settings": { "foreground": "#616161", "fontStyle": "" }
		},
		{
			"name": "VSkript Variable Normal, Runtime",
			"scope": [
				"vskript.variable.normal",
				"vskript.variable.runtime"
			],
			"settings": { "foreground": "#616161", "fontStyle": "bold" }
		}
	]
}