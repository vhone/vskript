{
	"name": "vskript",
	"displayName": "VSkript",
	"description": "Visual Skript",
	"author": {
		"name": "vhone",
		"email": "v_hone@naver.com",
		"url": "https://blog.naver.com/v_hone"
	},
	"version": "0.0.7",
	"engines": {
		"vscode": "^1.56.0"
	},
	"publisher": "Vhone",
	"repository": {
		"type": "git",
		"url": "https://github.com/vhone/vskript.git"
	},
	"icon": "img/cover.png",
	"categories": [],
	"activationEvents": [
		"*"
	],
	"main": "./out/extension.js",
	"contributes": {
		"languages": [
			{
				"id": "vskript",
				"aliases": [
					"skript",
					"sk"
				],
				"extensions": [
					".sk"
				]
			}
		],
		"grammars": [
			{
				"language": "vskript",
				"scopeName": "source.sk",
				"path": "themes/vskript.tmLanguage.json"
			}
		],
		"themes": [
			{
				"label": "VSkript (Dark)",
				"id": "vskript",
				"uiTheme": "vs-dark",
				"path": "./themes/vskript_default.json"
			}
		],
		"semanticTokenTypes": [
			{
				"id": "templateType",
				"superType": "type",
				"description": "A templete type"
			}
		],
		"semanticTokenModifiers": [
			{
				"id": "native",
				"description" : "test token modifiers"
			}
		],
		"configurationDefaults": {
			"[vskript]": {
				"editor.semanticHighlighting.enabled": true
			}
		},
		"configuration":[
			{
				"title": "VSkript",
				"properties": {
					"vskript.syntaxHighlight.comment": {
						"type": "string",
						"default": "e0e0e0"
					},
					"vskript.syntaxHighlight.text": {
						"type": "string",
						"default": "78ac79"
					},
					"vskript.syntaxHighlight.number": {
						"type": "string",
						"default": "ffffff"
					},
					"vskript.syntaxHighlight.options": {
						"type": "string",
						"default": "ff2e97"
					},
					"vskript.syntaxHighlight.aliases": {
						"type": "string",
						"default": "7fd8f3"
					},
					"vskript.syntaxHighlight.event": {
						"type": "string",
						"default": "ffe683"
					},
					"vskript.syntaxHighlight.command": {
						"type": "string",
						"default": "ffe683"
					},
					"vskript.syntaxHighlight.function": {
						"type": "string",
						"default": "b86fe9"
					},
					"vskript.syntaxHighlight.variable": {
						"type": "string",
						"default": "616161"
					},
					"vskript.syntaxHighlight.grammar": {
						"type": "string",
						"default": "ec8d59"
					}
				}
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./",
		"pretest": "npm run compile && npm run lint",
		"lint": "eslint src --ext ts",
		"test": "node ./out/test/runTest.js",
		"publish": "vsce package"
	},
	"devDependencies": {
		"@types/vscode": "^1.56.0",
		"@types/glob": "^7.1.3",
		"@types/mocha": "^8.0.4",
		"@types/node": "^12.11.7",
		"eslint": "^7.19.0",
		"@typescript-eslint/eslint-plugin": "^4.14.1",
		"@typescript-eslint/parser": "^4.14.1",
		"glob": "^7.1.6",
		"mocha": "^8.2.1",
		"typescript": "^4.1.3",
		"vscode-test": "^1.5.0"
	}
}
